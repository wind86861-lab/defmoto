# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="DEFT MOTO"

# Telegram
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=DeftMotoBot
# Bot token from @BotFather — enables the live service-chat relay.
TELEGRAM_BOT_TOKEN=
# Optional: pre-set the operator's Telegram chat id. If empty, the first
# person to press /start on the bot becomes the operator.
TELEGRAM_OPERATOR_CHAT_ID=

# Admin panel
ADMIN_PASSWORD=deftmoto2026
# Long random string used to sign the admin session cookie — change in prod.
ADMIN_SECRET=

# Payments — Payme (Paycom). Endpoint: https://<domain>/api/payment/payme
# Account field in the Payme cabinet: order_id
PAYME_KEY=
# Sandbox key (test.paycom.uz) — the endpoint accepts either key.
PAYME_TEST_KEY=
PAYME_ALLOWED_IPS=
# Cashbox id (m) — enables the real checkout redirect on the client.
NEXT_PUBLIC_PAYME_MERCHANT_ID=

# Payments — Click. Prepare/Complete URL: https://<domain>/api/payment/click
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=
CLICK_ALLOWED_IPS=
# service_id + merchant_id — enable the real checkout redirect on the client.
NEXT_PUBLIC_CLICK_SERVICE_ID=
NEXT_PUBLIC_CLICK_MERCHANT_ID=

# Delivery — BTS (bts.uz) courier. Inert until BTS_LOGIN + BTS_PASSWORD set.
# Test host: https://apitest.bts.uz:28345  (prod host from BTS: set BTS_BASE_URL)
BTS_BASE_URL=https://apitest.bts.uz:28345
BTS_LOGIN=
BTS_PASSWORD=
BTS_ENVIRONMENT=test
BTS_LANGUAGE=uz
# Shared secret for the incoming status webhook (optional but recommended).
BTS_WEBHOOK_KEY=
# Shop = sender. city_code from BTS directory (region → city).
BTS_SENDER_NAME=DEFT MOTO
BTS_SENDER_PHONE=
BTS_SENDER_ADDRESS=
BTS_SENDER_CITY_CODE=
BTS_SENDER_BRANCH_CODE=
# Defaults for dispatch.
BTS_PICKUP_TYPE=courier
BTS_DEFAULT_WEIGHT=1

# API (later — backend)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Feature flags
NEXT_PUBLIC_USE_MOCK_API=true
NEXT_PUBLIC_DEMO_MODE=true
